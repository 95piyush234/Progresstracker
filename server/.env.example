PORT=5000
NODE_ENV=development

MONGODB_URI=mongodb://127.0.0.1:27017/progress-tracker-saas

CLIENT_URL=http://localhost:5173
CLIENT_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
REFRESH_COOKIE_NAME=pt_refresh_token

BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=20

MAIL_FROM=Progress Tracker <no-reply@yourdomain.com>
MAIL_PROVIDER=smtp
RESEND_API_KEY=
BREVO_API_KEY=
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
MAIL_REQUEST_TIMEOUT_MS=15000


PASSWORD_RESET_EXPIRES_MINUTES=30
EMAIL_OTP_EXPIRES_MINUTES=10

UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5
